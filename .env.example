VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Server-side only — used by the `scan-fridge` Supabase Edge Function for Claude
# vision. Do NOT prefix with VITE_ (that would expose it to the browser bundle).
# Set it as a Supabase secret, not in this client .env:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
